# Set to 1 to run Postgres + REST API only (no X client — good for local API tests)
# SKIP_TWITTER=1

# Twitter/X API credentials (OAuth 1.0a — requires Basic tier $100/mo)
TWITTER_APP_KEY=
TWITTER_APP_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

# PostgreSQL connection string
DATABASE_URL=postgresql://cabot:cabot_dev@localhost:5432/cabot

# API server port (default: 3000)
API_PORT=3000

# Polling interval in milliseconds (default: 90000 = 90s)
# Do NOT set below 60000 — rate limit is 15 reads per 15 min per user
POLL_INTERVAL_MS=90000
